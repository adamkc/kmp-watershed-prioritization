# R
.Rhistory
.Rapp.history
.RData
.RDataTmp
.Ruserdata
.Rproj.user/
*.Rproj
.Renviron
.Rprofile

# renv (track lockfile, ignore the library)
renv/library/
renv/local/
renv/cellar/
renv/staging/

# Python (in case we add a Pyodide/shinylive-python variant later)
__pycache__/
*.pyc
.venv/
venv/
.ipynb_checkpoints/

# Claude Code (keep shared settings, ignore per-user)
.claude/settings.local.json

# OS / editor
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# Build / deploy artifacts
_site/
_site_local/
_shinylive_test/
site_libs/
shinylive/
docs/_site/

# Logs
*.log

# Local user data (do not commit user CSVs uploaded for testing)
data/user_uploads/

# Raw source data for metric acquisition (large geospatial downloads,
# tracked via docs/data-acquisition.md, not committed to the repo)
data/source/

# All-CA HUC10 boundary layer. The committed kmp_huc10.geojson is the
# small KMP-only subset (~1 MB) used by the shinylive bundle. The full
# CA layer (~7 MB, ~1128 features) is generated by
# scripts/prepare_ca_huc10.R and split by scripts/split_huc10.R; it
# stays local so non-KMP HUC10 uploads still work for local users
# without bloating the deployed bundle.
data/kmp_huc10_ca.geojson
